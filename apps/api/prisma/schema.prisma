generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "sqlserver"
}

// ── Business Partners ──────────────────────────────────────────

model BusinessPartnerGroup {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?  @db.NVarChar(Max)
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  partners BusinessPartner[]

  @@index([code])
  @@index([status])
  @@map("business_partner_groups")
}

model PaymentTerm {
  id             String   @id @default(cuid())
  code           String   @unique
  name           String
  description    String?  @db.NVarChar(Max)
  days           Int      @default(0)
  discountDays   Int?
  discountPercent Decimal? @db.Decimal(9, 4)
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  partners BusinessPartner[]

  @@index([code])
  @@index([status])
  @@map("payment_terms")
}

model BusinessPartner {
  id                      String   @id @default(cuid())
  code                    String   @unique
  type                    String   @default("CUSTOMER")
  status                  String   @default("ACTIVE")

  // Core identity
  name                    String
  legalName               String?
  commercialName          String?
  description             String?  @db.NVarChar(Max)

  // Classification
  groupId                 String?
  group                   BusinessPartnerGroup? @relation(fields: [groupId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paymentTermId           String?
  paymentTerm             PaymentTerm?           @relation(fields: [paymentTermId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  // Organization scope
  companyId               String?
  branchId                String?

  // Tax / Commercial
  taxNumber               String?
  commercialRegistrationNo String?
  vatRegistrationNo       String?
  nationalIdOrRegistryNo  String?

  // Contact summary
  phone                   String?
  mobile                  String?
  email                   String?
  website                 String?

  // Credit / Control
  creditLimit             Decimal? @db.Decimal(18, 4)
  creditUsed              Decimal? @db.Decimal(18, 4) @default(0)
  allowCredit             Boolean  @default(false)
  isBlocked               Boolean  @default(false)
  blockReason             String?
  blockNotes              String?  @db.NVarChar(Max)
  blockedAt               DateTime?
  blockedById             String?

  // Customer / Supplier flags
  isCustomer              Boolean  @default(false)
  isSupplier              Boolean  @default(false)

  // Notes
  notes                   String?  @db.NVarChar(Max)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  deletedAt               DateTime?

  contacts    BusinessPartnerContact[]
  addresses   BusinessPartnerAddress[]
  bankAccounts BusinessPartnerBankAccount[]

  @@index([code])
  @@index([type])
  @@index([status])
  @@index([groupId])
  @@index([paymentTermId])
  @@index([companyId])
  @@index([branchId])
  @@index([taxNumber])
  @@index([commercialRegistrationNo])
  @@index([email])
  @@index([phone])
  @@index([isCustomer])
  @@index([isSupplier])
  @@index([isBlocked])
  @@map("business_partners")
}

model BusinessPartnerContact {
  id        String   @id @default(cuid())
  partnerId String
  partner   BusinessPartner @relation(fields: [partnerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  type      String   @default("GENERAL")
  name      String
  jobTitle  String?
  phone     String?
  mobile    String?
  email     String?
  isPrimary Boolean  @default(false)
  notes     String?  @db.NVarChar(Max)
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([partnerId])
  @@index([type])
  @@index([email])
  @@index([phone])
  @@index([isPrimary])
  @@map("business_partner_contacts")
}

model BusinessPartnerAddress {
  id           String   @id @default(cuid())
  partnerId    String
  partner      BusinessPartner @relation(fields: [partnerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  type         String   @default("BILLING")
  label        String?
  country      String?
  city         String?
  district     String?
  street       String?
  buildingNo   String?
  postalCode   String?
  addressLine1 String?  @db.NVarChar(500)
  addressLine2 String?  @db.NVarChar(500)
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)
  isPrimary    Boolean  @default(false)
  notes        String?  @db.NVarChar(Max)
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  @@index([partnerId])
  @@index([type])
  @@index([city])
  @@index([isPrimary])
  @@map("business_partner_addresses")
}

model BusinessPartnerBankAccount {
  id            String   @id @default(cuid())
  partnerId     String
  partner       BusinessPartner @relation(fields: [partnerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  bankName      String
  accountName   String?
  accountNumber String?
  iban          String?
  swiftCode     String?
  currency      String?
  isPrimary     Boolean  @default(false)
  notes         String?  @db.NVarChar(Max)
  status        String   @default("ACTIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@index([partnerId])
  @@index([iban])
  @@index([isPrimary])
  @@map("business_partner_bank_accounts")
}

// ── Existing Models ────────────────────────────────────────────

model Company {
  id        String    @id @default(cuid())
  code      String    @unique
  name      String
  legalName String?
  taxNumber String?
  phone     String?
  email     String?
  address   String?
  logo      String?
  status    String    @default("ACTIVE")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  branches    Branch[]
  departments Department[]
  users       User[]
  warehouses  Warehouse[]
  machines    Machine[]
  counts      InventoryCount[]
  movements   InventoryMovement[]
  adjustments InventoryAdjustment[]

  @@index([status])
  @@index([code])
  @@index([createdAt])
  @@map("companies")
}

model Branch {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  code      String
  name      String
  address   String?
  phone     String?
  status    String    @default("ACTIVE")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  departments Department[]
  users       User[]
  warehouses  Warehouse[]
  machines    Machine[]
  numberSeqs  NumberSequence[]
  counts      InventoryCount[]
  movements   InventoryMovement[]
  adjustments InventoryAdjustment[]

  @@unique([companyId, code])
  @@index([status])
  @@index([createdAt])
  @@map("branches")
}

model Department {
  id        String       @id @default(cuid())
  companyId String
  company   Company      @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  branchId  String?
  branch    Branch?      @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parentId  String?
  parent    Department?  @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children  Department[] @relation("DepartmentHierarchy")
  code      String
  name      String
  status    String       @default("ACTIVE")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?

  users    User[]
  machines Machine[]

  @@unique([companyId, code])
  @@index([branchId])
  @@index([status])
  @@index([createdAt])
  @@map("departments")
}

model User {
  id               String      @id @default(cuid())
  email            String      @unique
  passwordHash     String
  name             String
  phone            String?
  avatar           String?
  status           String      @default("ACTIVE")
  companyId        String?
  company          Company?    @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  branchId         String?
  branch           Branch?     @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  departmentId     String?
  department       Department? @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  twoFactorEnabled Boolean     @default(false)
  twoFactorSecret  String?
  lastLoginAt      DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deletedAt        DateTime?

  roles                    UserRole[]
  notifications            Notification[]
  attachments              Attachment[]
  auditLogs                AuditLog[]
  requestedMaintenanceReqs MaintenanceRequest[] @relation("MaintenanceRequestRequestedBy")
  assignedMaintenanceReqs  MaintenanceRequest[] @relation("MaintenanceRequestAssignedTo")
  requestedTasks           MaintenanceTask[]    @relation("MaintenanceTaskAssignedTo")
  checklistExecutionCompletions         MaintenanceChecklistExecution[]              @relation("MaintenanceChecklistExecutionCompletedBy")
  checklistExecutionItemCompletions     MaintenanceChecklistExecutionItem[]          @relation("MaintenanceChecklistExecutionItemCompletedBy")
  createdConversations                  InternalConversation[]                       @relation("UserCreatedConversations")
  conversationParticipants              InternalConversationParticipant[]
  sentMessages                         InternalMessage[]                            @relation("UserSentMessages")

  @@index([email])
  @@index([status])
  @@index([name])
  @@index([companyId])
  @@index([branchId])
  @@index([departmentId])
  @@index([status, createdAt])
  @@map("users")
}

model Role {
  id          String    @id @default(cuid())
  code        String    @unique
  name        String
  description String?
  isSystem    Boolean   @default(false)
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  users       UserRole[]
  permissions RolePermission[]

  @@index([code])
  @@index([status])
  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  module      String
  action      String
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]

  @@index([module])
  @@index([action])
  @@index([module, action])
  @@index([status])
  @@map("permissions")
}

model UserRole {
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  action    String
  entity    String
  entityId  String?
  details   String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
  @@index([entity, entityId])
  @@index([userId, action])
  @@index([entity, createdAt])
  @@map("audit_logs")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  title     String
  message   String
  type      String   @default("INFO")
  read      Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([read, createdAt])
  @@map("notifications")
}

model NotificationRule {
  id              String   @id @default(cuid())
  code            String   @unique
  nameAr          String
  nameEn          String
  description     String?
  eventType       String
  channel         String   @default("IN_APP")
  severity        String   @default("INFO")
  enabled         Boolean  @default(true)
  targetRoleId    String?
  targetPermission String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([enabled])
  @@index([eventType])
  @@map("notification_rules")
}

model Attachment {
  id           String   @id @default(cuid())
  entityName   String
  entityId     String
  originalName String
  filePath     String
  mimeType     String
  size         Int
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdAt    DateTime @default(now())

  @@index([entityName])
  @@index([entityId])
  @@map("attachments")
}

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  group       String
  label       String
  description String?
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([group])
  @@map("system_settings")
}

model NumberSequence {
  id            String    @id @default(cuid())
  code          String    @unique
  name          String
  prefix        String
  suffix        String?
  currentNumber Int       @default(0)
  padding       Int       @default(6)
  scope         String    @default("GLOBAL")
  companyId     String?
  branchId      String?
  branch        Branch?   @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  resetPolicy   String    @default("NEVER")
  lastResetAt   DateTime?
  status        String    @default("ACTIVE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("number_sequences")
}

model Warehouse {
  id        String    @id @default(cuid())
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  branchId  String?
  branch    Branch?   @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  code      String
  name      String
  location  String?
  status    String    @default("ACTIVE")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  locations  WarehouseLocation[]
  balances   InventoryBalance[]
  counts     InventoryCount[]
  movements  InventoryMovement[]
  adjustments InventoryAdjustment[]

  @@unique([companyId, code])
  @@index([branchId])
  @@index([status])
  @@index([createdAt])
  @@map("warehouses")
}

model WarehouseLocation {
  id          String    @id @default(cuid())
  warehouseId String
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  code        String
  name        String
  barcode     String?
  status      String    @default("ACTIVE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  balances       InventoryBalance[]
  countLines     InventoryCountLine[]
  movementLines  InventoryMovementLine[]
  adjustmentLines InventoryAdjustmentLine[]

  @@unique([warehouseId, code])
  @@index([status])
  @@index([barcode])
  @@map("warehouse_locations")
}

model ProductCategory {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  description String?
  parentId    String?
  parent      ProductCategory?  @relation("ProductCategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    ProductCategory[] @relation("ProductCategoryHierarchy")
  status      String            @default("ACTIVE")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  products Product[]

  @@index([parentId])
  @@index([status])
  @@map("product_categories")
}

model Product {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  description String?
  categoryId  String?
  category    ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  unit        String
  barcode     String?
  qrCode      String?
  image       String?
  minStock    Float            @default(0)
  maxStock    Float            @default(0)
  status      String           @default("ACTIVE")
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  balances            InventoryBalance[]
  parts               MachinePart[]
  countLines          InventoryCountLine[]
  movementLines       InventoryMovementLine[]
  adjustmentLines     InventoryAdjustmentLine[]
  requestPartUsages   MaintenanceRequestPartUsage[]

  @@index([categoryId])
  @@index([code])
  @@index([status])
  @@index([name])
  @@index([createdAt])
  @@index([categoryId, status])
  @@index([status, createdAt])
  @@map("products")
}

model InventoryBalance {
  id           String             @id @default(cuid())
  warehouseId  String
  warehouse    Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  locationId   String?
  location     WarehouseLocation? @relation(fields: [locationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId    String
  product      Product            @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  quantity     Float              @default(0)
  batchNumber  String?
  serialNumber String?
  expiryDate   DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@unique([warehouseId, productId, batchNumber, serialNumber])
  @@index([warehouseId])
  @@index([productId])
  @@index([locationId])
  @@index([quantity])
  @@index([updatedAt])
  @@index([warehouseId, productId])
  @@map("inventory_balances")
}

model InventoryCount {
  id             String    @id @default(cuid())
  countNumber    String    @unique
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  branchId       String?
  branch         Branch?   @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouseId    String
  warehouse      Warehouse @relation(fields: [warehouseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status         String    @default("DRAFT")
  countDate      DateTime  @default(now())
  startedAt      DateTime?
  completedAt    DateTime?
  cancelledAt    DateTime?
  createdById    String?
  startedById    String?
  completedById  String?
  cancelledById  String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  lines         InventoryCountLine[]
  adjustments   InventoryAdjustment[]

  @@index([companyId])
  @@index([branchId])
  @@index([warehouseId])
  @@index([status])
  @@index([countDate])
  @@index([countNumber])
  @@index([createdAt])
  @@index([warehouseId, status])
  @@index([status, createdAt])
  @@map("inventory_counts")
}

model InventoryCountLine {
  id                  String    @id @default(cuid())
  countId             String
  count               InventoryCount @relation(fields: [countId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId           String
  product             Product       @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouseLocationId String?
  warehouseLocation   WarehouseLocation? @relation(fields: [warehouseLocationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  systemQty           Float         @default(0)
  countedQty          Float?
  differenceQty       Float?
  status              String        @default("PENDING")
  countedAt           DateTime?
  verifiedAt          DateTime?
  countedById         String?
  verifiedById        String?
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  deletedAt           DateTime?

  @@unique([countId, productId, warehouseLocationId])
  @@index([countId])
  @@index([productId])
  @@index([warehouseLocationId])
  @@index([status])
  @@index([countId, status])
  @@index([countId, productId])
  @@map("inventory_count_lines")
}

model InventoryMovement {
  id             String    @id @default(cuid())
  movementNumber String    @unique
  companyId      String
  company        Company   @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  branchId       String?
  branch         Branch?   @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouseId    String
  warehouse      Warehouse @relation(fields: [warehouseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  movementType   String
  status         String    @default("DRAFT")
  sourceType     String?
  sourceId       String?
  movementDate   DateTime  @default(now())
  postedAt       DateTime?
  cancelledAt    DateTime?
  createdById    String?
  postedById     String?
  cancelledById  String?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  lines InventoryMovementLine[]

  @@index([companyId])
  @@index([branchId])
  @@index([warehouseId])
  @@index([movementType])
  @@index([status])
  @@index([movementDate])
  @@index([movementNumber])
  @@index([createdAt])
  @@index([warehouseId, status])
  @@index([status, movementDate])
  @@map("inventory_movements")
}

model InventoryMovementLine {
  id                  String    @id @default(cuid())
  movementId          String
  movement            InventoryMovement @relation(fields: [movementId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId           String
  product             Product           @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouseLocationId String?
  warehouseLocation   WarehouseLocation? @relation(fields: [warehouseLocationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  quantity            Float
  unit                String?
  direction           String
  notes               String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@index([movementId])
  @@index([productId])
  @@index([warehouseLocationId])
  @@index([movementId, productId])
  @@map("inventory_movement_lines")
}

model InventoryAdjustment {
  id                String    @id @default(cuid())
  adjustmentNumber  String    @unique
  companyId         String
  company           Company   @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  branchId          String?
  branch            Branch?   @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouseId       String
  warehouse         Warehouse @relation(fields: [warehouseId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  inventoryCountId  String?
  inventoryCount    InventoryCount? @relation(fields: [inventoryCountId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status            String    @default("DRAFT")
  reason            String?
  adjustmentDate    DateTime  @default(now())
  postedAt          DateTime?
  cancelledAt       DateTime?
  createdById       String?
  postedById        String?
  cancelledById     String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  lines InventoryAdjustmentLine[]

  @@index([companyId])
  @@index([branchId])
  @@index([warehouseId])
  @@index([inventoryCountId])
  @@index([status])
  @@index([adjustmentDate])
  @@index([adjustmentNumber])
  @@index([createdAt])
  @@index([warehouseId, status])
  @@index([status, adjustmentDate])
  @@map("inventory_adjustments")
}

model InventoryAdjustmentLine {
  id                  String    @id @default(cuid())
  adjustmentId        String
  adjustment          InventoryAdjustment @relation(fields: [adjustmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId           String
  product             Product             @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  warehouseLocationId String?
  warehouseLocation   WarehouseLocation?  @relation(fields: [warehouseLocationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  systemQty           Float
  countedQty          Float
  differenceQty       Float
  notes               String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@index([adjustmentId])
  @@index([productId])
  @@index([warehouseLocationId])
  @@index([adjustmentId, productId])
  @@map("inventory_adjustment_lines")
}

model MachineCategory {
  id          String            @id @default(cuid())
  code        String            @unique
  name        String
  description String?
  parentId    String?
  parent      MachineCategory?  @relation("MachineCategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    MachineCategory[] @relation("MachineCategoryHierarchy")
  status      String            @default("ACTIVE")
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?

  machines Machine[]

  @@index([parentId])
  @@index([status])
  @@map("machine_categories")
}

model Machine {
  id           String           @id @default(cuid())
  code         String           @unique
  name         String
  categoryId   String?
  category     MachineCategory? @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  companyId    String?
  company      Company?         @relation(fields: [companyId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  branchId     String?
  branch       Branch?          @relation(fields: [branchId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  departmentId String?
  department   Department?      @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  model        String?
  serialNumber String?
  manufacturer String?
  purchaseDate DateTime?
  warrantyEnd  DateTime?
  location     String?
  status       String           @default("ACTIVE")
  qrCode       String?
  image        String?
  notes        String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?

  parts           MachinePart[]
  documents       MachineDocument[]
  maintenanceReqs MaintenanceRequest[]
  schedules       MaintenanceSchedule[]
  downtimeLogs    DowntimeLog[]

  @@index([categoryId])
  @@index([companyId])
  @@index([branchId])
  @@index([departmentId])
  @@index([code])
  @@index([status])
  @@index([createdAt])
  @@index([status, categoryId])
  @@index([companyId, status])
  @@map("machines")
}

model MachinePart {
  id         String   @id @default(cuid())
  code       String   @unique
  name       String
  machineId  String?
  machine    Machine? @relation(fields: [machineId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId  String?
  product    Product? @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  partNumber String?
  quantity   Float    @default(0)
  minStock   Float    @default(0)
  unit       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([machineId])
  @@index([productId])
  @@index([code])
  @@index([name])
  @@map("machine_parts")
}

model MachineDocument {
  id        String   @id @default(cuid())
  machineId String
  machine   Machine  @relation(fields: [machineId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  title     String
  type      String
  fileUrl   String
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([machineId])
  @@map("machine_documents")
}

model MaintenanceRequest {
  id            String    @id @default(cuid())
  requestNumber String    @unique
  machineId     String
  machine       Machine   @relation(fields: [machineId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  type          String
  priority      String    @default("MEDIUM")
  title         String
  description   String?
  status        String    @default("OPEN")
  requestedById String?
  requestedBy   User?     @relation("MaintenanceRequestRequestedBy", fields: [requestedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignedToId  String?
  assignedTo    User?     @relation("MaintenanceRequestAssignedTo", fields: [assignedToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  startDate     DateTime?
  endDate       DateTime?
  downtimeHours Float?
  cost          Float?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  tasks               MaintenanceTask[]
  schedules           MaintenanceSchedule[]
  downtimeLogs        DowntimeLog[]
  partUsages          MaintenanceRequestPartUsage[]
  costEntries         MaintenanceRequestCostEntry[]
  checklistExecutions MaintenanceChecklistExecution[]

  @@index([machineId])
  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([requestedById])
  @@index([assignedToId])
  @@index([requestNumber])
  @@index([createdAt])
  @@index([status, priority])
  @@index([machineId, status])
  @@index([assignedToId, status])
  @@index([status, createdAt])
  @@map("maintenance_requests")
}

model MaintenanceTask {
  id           String             @id @default(cuid())
  requestId    String
  request      MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  title        String
  description  String?
  status       String             @default("PENDING")
  assignedToId String?
  assignedTo   User?              @relation("MaintenanceTaskAssignedTo", fields: [assignedToId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  startedAt    DateTime?
  completedAt  DateTime?
  cancelledAt  DateTime?
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  @@index([requestId])
  @@index([assignedToId])
  @@index([status])
  @@index([requestId, status])
  @@index([assignedToId, status])
  @@index([completedAt])
  @@map("maintenance_tasks")
}

model MaintenanceSchedule {
  id           String              @id @default(cuid())
  machineId    String
  machine      Machine             @relation(fields: [machineId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  requestId    String?
  request      MaintenanceRequest? @relation(fields: [requestId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  type         String
  frequency    String
  intervalDays Int?
  startDate    DateTime
  endDate      DateTime?
  title        String
  description  String?
  status       String              @default("ACTIVE")
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  checklistItems    MaintenanceChecklistItem[]
  checklistExecutions MaintenanceChecklistExecution[]

  @@index([machineId])
  @@index([status])
  @@index([type])
  @@index([machineId, status])
  @@index([startDate])
  @@index([endDate])
  @@map("maintenance_schedules")
}

model MaintenanceChecklistItem {
  id          String              @id @default(cuid())
  scheduleId  String
  schedule    MaintenanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  title       String
  description String?
  sortOrder   Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  executionItems  MaintenanceChecklistExecutionItem[]

  @@index([scheduleId])
  @@map("maintenance_checklist_items")
}

model DowntimeLog {
  id              String              @id @default(cuid())
  machineId       String
  machine         Machine             @relation(fields: [machineId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  requestId       String?
  request         MaintenanceRequest? @relation(fields: [requestId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Float?
  reason          String
  notes           String?
  cancelledAt     DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([machineId])
  @@index([requestId])
  @@index([startTime])
  @@index([machineId, startTime])
  @@index([requestId, cancelledAt])
  @@index([endTime, cancelledAt])
  @@map("downtime_logs")
}

// ── Maintenance Request Part Usage ──────────────────────────────
model MaintenanceRequestPartUsage {
  id        String   @id @default(cuid())
  requestId String
  request   MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  quantity  Float
  unitCost  Float?
  totalCost Float?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([requestId])
  @@index([productId])
  @@map("maintenance_request_part_usages")
}

// ── Maintenance Request Cost Entry ──────────────────────────────
model MaintenanceRequestCostEntry {
  id          String   @id @default(cuid())
  requestId   String
  request     MaintenanceRequest @relation(fields: [requestId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  type        String
  description String?
  amount      Float
  incurredAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([requestId])
  @@map("maintenance_request_cost_entries")
}

// ── Maintenance Checklist Execution ─────────────────────────────
model MaintenanceChecklistExecution {
  id          String   @id @default(cuid())
  scheduleId  String
  schedule    MaintenanceSchedule @relation(fields: [scheduleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  requestId   String?
  request     MaintenanceRequest? @relation(fields: [requestId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status      String   @default("IN_PROGRESS")
  startedAt   DateTime @default(now())
  completedAt DateTime?
  completedById String?
  completedBy   User?    @relation("MaintenanceChecklistExecutionCompletedBy", fields: [completedById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items MaintenanceChecklistExecutionItem[]

  @@index([scheduleId])
  @@index([requestId])
  @@index([status])
  @@index([scheduleId, status])
  @@index([requestId, status])
  @@map("maintenance_checklist_executions")
}

// ── Maintenance Checklist Execution Item ────────────────────────
model MaintenanceChecklistExecutionItem {
  id            String   @id @default(cuid())
  executionId   String
  execution     MaintenanceChecklistExecution @relation(fields: [executionId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  checklistItemId String
  checklistItem MaintenanceChecklistItem @relation(fields: [checklistItemId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status        String   @default("PENDING")
  passed        Boolean?
  notes         String?
  completedAt   DateTime?
  completedById String?
  completedBy   User?    @relation("MaintenanceChecklistExecutionItemCompletedBy", fields: [completedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([executionId])
  @@index([checklistItemId])
  @@map("maintenance_checklist_execution_items")
}

// ── Barcode / QR ────────────────────────────────────────────────

model BarcodeLabel {
  id                 String   @id @default(cuid())
  code               String   @unique
  value              String   @unique
  symbology          String   @default("QR_CODE")
  entityType         String
  entityId           String
  status             String   @default("ACTIVE")
  title              String?
  description        String?  @db.NVarChar(Max)
  qrPayload          String?  @db.NVarChar(Max)
  humanReadableValue String?
  labelTemplateCode  String?
  printCount         Int      @default(0)
  lastPrintedAt      DateTime?
  lastScannedAt      DateTime?
  scanCount          Int      @default(0)
  createdById        String?
  updatedById        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  scanEvents BarcodeScanEvent[]
  printJobs  BarcodePrintJob[]

  @@index([code])
  @@index([value])
  @@index([entityType])
  @@index([entityId])
  @@index([status])
  @@index([symbology])
  @@index([entityType, entityId])
  @@index([status, entityType])
  @@index([entityType, entityId, status])
  @@index([status, createdAt])
  @@map("barcode_labels")
}

model BarcodeScanEvent {
  id           String   @id @default(cuid())
  labelId      String?
  label        BarcodeLabel? @relation(fields: [labelId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  scannedValue String
  symbology    String?
  purpose      String   @default("GENERAL_LOOKUP")
  result       String   @default("SUCCESS")
  source       String   @default("WEB")
  entityType   String?
  entityId     String?
  contextType  String?
  contextId    String?
  message      String?  @db.NVarChar(500)
  metadata     String?  @db.NVarChar(Max)
  scannedById  String?
  scannedAt    DateTime @default(now())
  ipAddress    String?
  userAgent    String?

  @@index([scannedValue])
  @@index([labelId])
  @@index([result])
  @@index([purpose])
  @@index([entityType])
  @@index([entityId])
  @@index([contextType, contextId])
  @@index([scannedById])
  @@index([scannedAt])
  @@index([labelId, result])
  @@index([scannedById, scannedAt])
  @@map("barcode_scan_events")
}

model BarcodeLabelTemplate {
  id           String   @id @default(cuid())
  code         String   @unique
  name         String
  description  String?  @db.NVarChar(Max)
  symbology    String   @default("QR_CODE")
  entityType   String?
  widthMm      Decimal? @db.Decimal(9, 2)
  heightMm     Decimal? @db.Decimal(9, 2)
  templateData String?  @db.NVarChar(Max)
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  @@index([code])
  @@index([symbology])
  @@index([entityType])
  @@index([status])
  @@index([status, entityType])
  @@map("barcode_label_templates")
}

model BarcodePrintJob {
  id            String   @id @default(cuid())
  labelId       String?
  label         BarcodeLabel? @relation(fields: [labelId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  templateId    String?
  entityType    String?
  entityId      String?
  printerName   String?
  copies        Int      @default(1)
  status        String   @default("PENDING")
  printedById   String?
  jobType       String   @default("LABEL")
  note          String?  @db.NVarChar(500)
  metadata      String?  @db.NVarChar(Max)
  requestedAt   DateTime @default(now())
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@index([labelId])
  @@index([templateId])
  @@index([entityType, entityId])
  @@index([status])
  @@index([printedById])
  @@index([requestedAt])
  @@map("barcode_print_jobs")
}

// ── Internal Messaging ──────────────────────────────────────────

model InternalConversation {
  id              String                           @id @default(cuid())
  title           String?                          @db.NVarChar(200)
  createdByUserId String
  createdBy       User                             @relation("UserCreatedConversations", fields: [createdByUserId], references: [id])
  lastMessageAt   DateTime?
  createdAt       DateTime                         @default(now())
  updatedAt       DateTime                         @updatedAt
  deletedAt       DateTime?
  participants    InternalConversationParticipant[]
  messages        InternalMessage[]

  @@index([createdByUserId])
  @@index([lastMessageAt])
  @@map("internal_conversations")
}

model InternalConversationParticipant {
  id             String             @id @default(cuid())
  conversationId String
  conversation   InternalConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId         String
  user           User               @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  joinedAt       DateTime           @default(now())
  lastReadAt     DateTime?

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("internal_conversation_participants")
}

model InternalMessage {
  id             String               @id @default(cuid())
  conversationId String
  conversation   InternalConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUserId   String
  sender         User                 @relation("UserSentMessages", fields: [senderUserId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  body           String               @db.NVarChar(Max)
  createdAt      DateTime             @default(now())
  editedAt       DateTime?
  deletedAt      DateTime?
  isSystem       Boolean              @default(false)

  @@index([conversationId, createdAt])
  @@index([senderUserId])
  @@map("internal_messages")
}
